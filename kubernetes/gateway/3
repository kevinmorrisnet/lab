apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: split-httproute
spec:
  parentRefs:
  - name: split-gateway
  hostnames:
  - split.example.com
  rules:
  - matches:
    - path:
        type: PathPrefix
        value: /
    backendRefs:
    - name: app-v1
      port: 80
  - matches:
    - path:
        type: PathPrefix
        value: /
    backendRefs:
    - name: app-v2
      port: 80
